meta {
  name: login
  type: http
  seq: 1
}

post {
  url: {{host}}/api/auth/login
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "username": "jane.doe",
    "password": "super-secret-password"
  }
}

script:post-response {
  bru.setEnvVar("sessionId", res.body.sessionId, { persist: true });
  bru.setEnvVar("authorizationHeader", `Bearer ${res.body.sessionId}`, { persist: true });
  bru.setEnvVar("userId", res.body.user.id, { persist: true });
}
