meta {
  name: change password
  type: http
  seq: 3
}

put {
  url: {{host}}/api/user/profile/password
  body: json
  auth: none
}

headers {
  Authorization: {{authorizationHeader}}
  content-type: application/json
}

body:json {
  {
    "currentPassword": "super-secret-password",
    "newPassword": "super-secret-password-2"
  }
}
