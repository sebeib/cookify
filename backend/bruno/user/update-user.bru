meta {
  name: update user
  type: http
  seq: 4
}

put {
  url: {{host}}/api/user/{{userId}}
  body: json
  auth: none
}

headers {
  Authorization: {{authorizationHeader}}
  content-type: application/json
}

body:json {
  {
    "username": "jane.doe",
    "password": "new-secret-password",
    "displayName": "Jane Doe",
    "roleId": "{{userRoleId}}"
  }
}
